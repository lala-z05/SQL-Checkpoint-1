/><column index="2" value="263"/><column index="3" value="68"/><column index="4" value="74"/><column index="5" value="167"/><column index="6" value="59"/><column index="7" value="81"/><column index="8" value="84"/><column index="9" value="84"/><column index="10" value="81"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT
    e.FirstName || ' ' || e.LastName AS Employee,
    m.FirstName || ' ' || m.LastName AS Manager
FROM Employees e
LEFT JOIN Employees m
ON e.ReportsTo = m.EmployeeID;</sql><current_tab id="0"/></tab_sql></sqlb_project>
